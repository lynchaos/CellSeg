<?xml version="1.0" encoding="utf-8"?>
<!--
    Restrict cleartext traffic to none.
    Whitelist only the HF endpoints used by this app.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- HF Spaces (cloud segmentation) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">hf.space</domain>
        <domain includeSubdomains="true">huggingface.co</domain>
    </domain-config>
</network-security-config>
