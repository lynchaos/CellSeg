<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base app theme — actual colours are in Compose Theme.kt -->
    <style name="Theme.CellSeg" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/teal_primary</item>
        <item name="android:statusBarColor">@color/teal_dark</item>
        <item name="android:navigationBarColor">@color/teal_dark</item>
    </style>

    <!-- Splash theme (keeps window background while Compose inflates) -->
    <style name="Theme.CellSeg.Splash" parent="Theme.CellSeg">
        <item name="android:windowSplashScreenBackground" tools:ignore="NewApi">@color/teal_primary</item>
    </style>
</resources>
