    <!-- ── Licence acknowledgement dialog ──────────────────────────────────── -->
    <string name="licence_title">Before you continue</string>
    <string name="licence_body">This app uses cell segmentation models from the Cellpose project,
created by the Pachitariu and Stringer labs at HHMI Janelia, and is
distributed with the authors\' permission.\n\nLocal mode uses Cellpose 3 (cyto3) weights, redistributed in ONNX
format. Cloud mode uses the public Cellpose-SAM Hugging Face Space.\n\nThis app is independent. It is not affiliated with, sponsored by, or
endorsed by the authors of Cellpose, Hugging Face, or any other party.\n\nUse it for whatever helps your work — research, education, hobby, or
production lab use. Just keep the attribution intact if you fork or
redistribute.</string>
    <string name="licence_accept">I understand and agree</string>

